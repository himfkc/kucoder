# 生产环境配置
VITE_APP_ENV = 'production'

# 后端接口地址 
# 后端若配置nginx反向代理 则为http://***.com 
# 生产环境建议开启https
# VITE_APP_BASE_API = 'http://127.0.0.1:8787'
VITE_APP_BASE_API = 'http://kux.com'

# 部署在站点子目录下需要填写此项 比如部署在站点根目录的web目录下 则填写'/web' 部署在根目录下则填写'/'
VITE_DEPLOY_DIR = '/vue'

# 是否在打包时开启压缩，支持 gzip 和 brotli 为空则不压缩
VITE_BUILD_COMPRESS = gzip