#[ENV] Application environment: production, development
ENV=development

#[DEBUG] Debug mode: true, false 生产环境建议关闭
APP_DEBUG=true

#[DB]
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_PREFIX=kc_
#全局自动写入时间戳字段
DB_AUTO_TIMESTAMP=true
# 字段缓存
DB_FIELDS_CACHE=false

#[redis]
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_PREFIX=kucoder: