# 开发环境配置
VITE_APP_ENV = 'development'

# 调试环境 后端接口地址 
# 后端若配置nginx反向代理 则为http://***.com 
# 生产环境建议开启https
# VITE_APP_BASE_API = 'http://127.0.0.1:8787'
VITE_APP_BASE_API = 'http://kux.com'

# 部署在站点子目录下需要填写此项 比如部署在站点根目录public的web目录下 则填写'/web' 调试环境一般不用
VITE_DEPLOY_DIR = '/vue'

#默认开启热更新
VITE_HMR = true


